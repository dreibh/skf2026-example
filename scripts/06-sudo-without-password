# Bash options:
set -euo pipefail


# WARNING:
# Make sure to only add this script if the password-less sudo is intended
# for the purpose of the VM!


# ###### Print script name, to make Packer output easier readable ###########
if command -v figlet >/dev/null && command -v print-utf8 >/dev/null ; then
   echo
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;31m█" "▀" "█\e[0m"
   figlet -w 156 "$(basename "$0")" | LC_ALL=C.UTF-8 print-utf8 -x 160 -n -C "\e[1;31m█\e[22m" "\e[1;31m█\e[0m"
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;31m█" "▄" "█\e[0m"
else
   echo -e "\e[1;31;22m########## $(basename "$0") ##########\e[0m"
fi

# Enable printing the command-lines executed:
set -x


# ###### Main program #######################################################

# ====== Check/set environment variables ====================================
if [ ! -v USER_NAME ] || [ "${USER_NAME}" == "" ] ; then
   echo >&2 "Usage: env USER_NAME=<user> $0"
   echo >&2 "Example: sudo env USER_NAME=nornetpp $0"
   exit 1
fi
UNAME="$(uname)"


# ====== Password-less "sudo" for the default user ==========================
if [ "${UNAME}" == "FreeBSD" ] ; then
   sudoersFile="/usr/local/etc/sudoers.d/99-${USER_NAME}"
else
   sudoersFile="/etc/sudoers.d/99-${USER_NAME}"
fi
mkdir -p "$(dirname "${sudoersFile}")"
cat >"${sudoersFile}" << EOF
# Allow password-less sudo for ${USER_NAME}:
${USER_NAME} ALL=(ALL) NOPASSWD:ALL
EOF
chown 0:0 "${sudoersFile}"
chmod 440 "${sudoersFile}"

# FreeBSD: Ensure the main sudoers configuration imports the sudoers.d directory:
if [ "${UNAME}" == "FreeBSD" ] ; then
   if [ -e /usr/local/etc/sudoers ] && \
      ! grep -q "^@includedir" /usr/local/etc/sudoers ; then
      echo "" >>/usr/local/etc/sudoers
      echo "@includedir /usr/local/etc/sudoers.d" >>/usr/local/etc/sudoers
   fi
fi


# ===== Validate sudoers syntax =============================================
if command -v visudo >/dev/null 2>&1 ; then
   visudo -c -f "${sudoersFile}"
fi
