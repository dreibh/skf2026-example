# Bash options:
set -euo pipefail


# ###### Print script name, to make Packer output easier readable ###########
if command -v figlet >/dev/null && command -v print-utf8 >/dev/null ; then
   echo
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;34m█" "▀" "█\e[0m"
   figlet -w 156 "$(basename "$0")" | LC_ALL=C.UTF-8 print-utf8 -x 160 -n -C "\e[1;34m█\e[22m" "\e[1;34m█\e[0m"
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;34m█" "▄" "█\e[0m"
else
   echo -e "\e[1;34;22m########## $(basename "$0") ##########\e[0m"
fi

# Enable printing the command-lines executed:
set -x


# ###### Main program #######################################################

# ====== Check/set environment variables ====================================
UNAME="$(uname)"


# ====== Configure System-Info ==============================================
if [ "${UNAME}" == "FreeBSD" ] ; then
   systemInfoDirectory="/usr/local/etc/system-info.d"
else
   systemInfoDirectory="/etc/system-info.d"
fi

# This directory is created by the configurations in ../files/$0
# Make sure that the corresponding configuration exists there!
INPUT_DIRECTORY="/tmp/system-info"

if [ -d "${INPUT_DIRECTORY}" ] ; then
   mkdir -p "${systemInfoDirectory}"
   find "${INPUT_DIRECTORY}" -type f -exec chmod +x {} \;
   find "${INPUT_DIRECTORY}" -type f -exec cp {} "${systemInfoDirectory}/" \;
else
   echo >&2 "ERROR: ${INPUT_DIRECTORY} does not exist!"
   exit 1
fi
