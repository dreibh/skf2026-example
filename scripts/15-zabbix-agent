# Bash options:
set -euo pipefail


# ====== Print script name, to make Packer output easier readable ===========
if command -v figlet >/dev/null && command -v print-utf8 >/dev/null ; then
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;34m█" "▀" "█\e[0m"
   figlet -w 156 "$(basename "$0")" | LC_ALL=C.UTF-8 print-utf8 -x 160 -n -C "\e[1;34m█\e[22m" "\e[1;34m█\e[0m"
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;34m█" "▄" "█\e[0m"
else
   echo -e "\e[1;34;22m########## $(basename "$0") ##########\e[0m"
fi

# Enable printing the command-lines executed:
set -x


# ====== Check/set environment variables ====================================
if [ ! -e /etc/os-release ] ; then
   echo >&2 "ERROR: /etc/os-release does not exist!"
   exit 1
fi
. /etc/os-release


# ====== Package installation ===============================================

# ------ Ubuntu/Debian ------------------------------------------------------
if [ "${ID}" == "ubuntu" ] || [ "${ID}" == "debian" ] ; then

   # ------ Add Zabbix Official Repository ----------------------------------
   zabbixVersion="7.4"
   cat >/etc/apt/sources.list.d/zabbix.list <<EOF
deb https://repo.zabbix.com/zabbix/${zabbixVersion}/stable/${ID} ${VERSION_CODENAME} main
# deb-src https://repo.zabbix.com/zabbix/${zabbixVersion}/stable/${ID} ${VERSION_CODENAME} main
EOF
   cat >/etc/apt/sources.list.d/zabbix-release.list <<EOF
deb https://repo.zabbix.com/zabbix/${zabbixVersion}/release/${ID} ${VERSION_CODENAME} main
# deb-src https://repo.zabbix.com/zabbix/${zabbixVersion}/release/${ID} ${VERSION_CODENAME} main
EOF
   cat >/etc/apt/sources.list.d/zabbix-tools.list <<EOF
deb https://repo.zabbix.com/zabbix-tools/debian-ubuntu ${VERSION_CODENAME} main
deb-src https://repo.zabbix.com/zabbix-tools/debian-ubuntu ${VERSION_CODENAME} main
EOF
#    cat >/etc/apt/sources.list.d/zabbix-release.list <<EOF
# # deb https://repo.zabbix.com/zabbix/${zabbixVersion}/unstable/${ID} ${VERSION_CODENAME} main
# # deb-src https://repo.zabbix.com/zabbix/${zabbixVersion}/unstable/${ID} ${VERSION_CODENAME} main
# EOF
   mkdir -p /etc/apt/trusted.gpg.d
   rm -f /etc/apt/trusted.gpg.d/zabbix-official-repo.gpg
   curl -fsSL https://repo.zabbix.com/zabbix-official-repo.key | \
      gpg --batch --dearmor -o /etc/apt/trusted.gpg.d/zabbix-official-repo.gpg
   apt-get update

   # ------ Install ---------------------------------------------------------
   packages="zabbix-agent"

   # shellcheck disable=SC2086
   env DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends ${packages}

   systemctl enable zabbix-agent || true
   systemctl start  zabbix-agent || true

# ------ Fedora -------------------------------------------------------------
elif [ "${ID}" == "fedora" ] ; then

   packages="zabbix-agent"

   # shellcheck disable=SC2086
   dnf install --setopt=install_weak_deps=False -y ${packages}

   systemctl enable zabbix-agent || true
   systemctl start  zabbix-agent || true

# ------ FreeBSD ------------------------------------------------------------
elif [ "${ID}" == "freebsd" ] ; then

   packages="zabbix7-agent"
   # shellcheck disable=SC2086
   pkg install -y ${packages}

   sysrc zabbix_agentd_enable="YES"
   service zabbix_agentd start || true

# ------ Unknown ------------------------------------------------------------
else

   echo >&2 "ERROR: Unknown ID ${ID} in /etc/os-release. The installation script may need an update for supporting this system!"
   exit 1

fi
