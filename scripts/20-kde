# Bash options:
set -euo pipefail


# ###########################################################################
# The "KDE" installation is based on the [Basic](#basic) installation.
#
# It must contain the following packages:
# * The [KDE Plasma Desktop](https://kde.org/plasma-desktop/) with Oxygen theme and [SDDM](https://github.com/sddm/sddm)
# * [DejaVu Fonts](https://dejavu-fonts.github.io/) (DejaVu fonts)
# * [Dia](https://wiki.gnome.org/Apps/Dia) (drawing tool)
# * [Firefox](https://www.mozilla.org/en-US/firefox/new/) (web browser)
# * [FractGen](https://www.nntb.no/~dreibh/fractalgenerator/) (fractal generator)
# * [LibreOffice](https://www.libreoffice.org/) (office suite)
# * [Gimp](https://www.gimp.org/) (graphics editing tool)
# * [Inkscape](https://inkscape.org/) (drawing tool)
# * [Kate](https://kate-editor.org/) (editor)
# * [Kile](https://kile.sourceforge.io/) (LaTeX editor)
# * [Konsole](https://konsole.kde.org/) (console)
# * [Noto Fonts](https://fonts.google.com/noto) (Noto fonts, complete UTF-8 character range)
# * [Okteta](https://apps.kde.org/okteta/) (Hex editor)
# * [Okular](https://okular.kde.org/) (file viewer, e.g. for PDF)
# * [Open Sans Fonts](https://fonts.google.com/specimen/Open+Sans) (Open Sans fonts)
# * [R](https://www.r-project.org/) (statistical computing suite)
# * [Strawberry Music Player](https://www.strawberrymusicplayer.org/) (audio player)
# * [Wireshark](https://www.wireshark.org/) (packet sniffer, GUI version)
#
# Further properties:
# * Configured KDE and SDDM login manager
# * Configured 4 virtual desktops
# * Configured switchable keyboard layouts
# * Configured Konsole keyboard shortcuts
# * Configured Firefox (hardened settings, enhanced privacy settings, as well as some add-ons like NoScript, uBlock Origin, etc.)
# * Configured Wireshark (predefined filters, coloring rules, etc.)
# * Ubuntu 22.04+: Firefox is installed from PPA mozillateam/ppa (<https://launchpad.net/~mozillateam/+archive/ubuntu/ppa/+packages>), instead of using the Snap package.
# ###########################################################################


# ====== Print script name, to make Packer output easier readable ===========
if command -v figlet >/dev/null && command -v print-utf8 >/dev/null ; then
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;32m█" "▀" "█\e[0m"
   figlet -w 156 "$(basename "$0")" | LC_ALL=C.UTF-8 print-utf8 -x 160 -n -C "\e[1;32m█\e[22m" "\e[1;32m█\e[0m"
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;32m█" "▄" "█\e[0m"
else
   echo -e "\e[1;34;22m########## $(basename "$0") ##########\e[0m"
fi

# Enable printing the command-lines executed:
set -x


# ====== Check/set environment variables ====================================
if [ ! -e /etc/os-release ] ; then
   echo >&2 "ERROR: /etc/os-release does not exist!"
   exit 1
fi
. /etc/os-release


# ====== Package installation ===============================================

# ------ Ubuntu/Debian ------------------------------------------------------
if [ "${ID}" == "ubuntu" ] || [ "${ID}" == "debian" ] ; then

   packages="
      dia
      fonts-dejavu
      fonts-noto
      fonts-open-sans
      fractgen
      kde-plasma-desktop
      gimp
      gstreamer1.0-libav
      inkscape
      kate
      kile
      konsole
      libreoffice
      okteta
      okular
      oxygen-icon-theme
      plasma-theme-oxygen
      sddm
      sddm-theme-breeze
      wireshark
   "

   # ------ Add Firefox package ---------------------------------------------
   if [ "${ID}" == "debian" ] ; then
      # Debian: firefox-esr instead of firefox!
      packages="${packages} firefox-esr"
   else
      packages="${packages} firefox"
   fi

   # ------ Ubuntu: Get Firefox from PPA, not via Snap ----------------------
   if [ "${ID}" == "ubuntu" ] ; then
      # shellcheck disable=SC2072,SC2071
      if [[ "${VERSION_ID}" > "21.10" ]] ; then
         cat >/etc/apt/preferences.d/firefox.pref <<EOF
# Use Firefox from PPA, instead of installing it via Snap!
Package: firefox
Pin: release o=LP-PPA-mozillateam
Pin-Priority: 1024
EOF
         add-apt-repository -sy ppa:mozillateam/ppa
      fi
   fi

   # NOTE: Try IPv4-only, if there is a problem. This seems to be necessary for Ubuntu 18.04.
   # shellcheck disable=SC2086
   env DEBIAN_FRONTEND=noninteractive apt-get install -y ${packages} || \
      env DEBIAN_FRONTEND=noninteractive apt-get install -o Acquire::ForceIPv4=true -y ${packages}

   # Oxygen style for Qt6 or Qt5:
   env DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends kde-style-oxygen-qt6 || \
      env DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends kde-style-oxygen-qt5

   # Only newer system versions have Strawberry, install Clementine instead:
   env DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends strawberry ||
      env DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends clementine

   # FIXME: Ubuntu 20.04 triggers GNOME Desktop as "recommends".
   #        Fix should be to use --no-install-recommends!
   # Work-around: disable GDM, to get SDDM working:
   env DEBIAN_FRONTEND=noninteractive apt-get autoremove -y gdm3 || true


# ------ Fedora -------------------------------------------------------------
elif [ "${ID}" == "fedora" ] ; then

   packages="
      dejavu-fonts-all
      dia
      firefox
      fractgen
      gimp
      inkscape
      kate
      @kde-desktop-environment
      kile
      konsole
      libreoffice
      google-noto-fonts-all
      okteta
      okular
      open-sans-fonts
      oxygen-fonts
      oxygen-icon-theme
      plasma-oxygen
      plasma-workspace-x11
      strawberry
      wireshark
   "

   # shellcheck disable=SC2086
   dnf install --setopt=install_weak_deps=False -y --allowerasing ${packages}
   dnf remove -y elisa-player

   systemctl set-default graphical.target
   systemctl disable plasma-setup.service

# ------ FreeBSD ------------------------------------------------------------
elif [ "${ID}" == "freebsd" ] ; then

   packages="
      dejavu
      dia
      firefox-esr
      fractgen
      gimp3-app
      inkscape
      kate
      kile
      konsole
      gstreamer1-plugins-soup
      libreoffice
      noto
      opensans-ttf
      okteta
      oxygen-fonts
      plasma6-plasma
      plasma6-oxygen
      plasma6-sddm-kcm
      R
      sddm
      strawberry

      wireshark
      xf86-video-vmware
      xorg
   "

   # shellcheck disable=SC2086
   pkg install -y ${packages}

   sysrc dbus_enable="YES" ; service dbus start || true
   sysrc sddm_enable="YES" ; service sddm start || true


   # ------ Unknown ------------------------------------------------------------
else

   echo >&2 "ERROR: Unknown ID ${ID} in /etc/os-release. The installation script may need an update for supporting this system!"
   exit 1

fi
