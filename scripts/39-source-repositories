# Bash options:
set -euo pipefail


# ###### Print script name, to make Packer output easier readable ###########
if command -v figlet >/dev/null && command -v print-utf8 >/dev/null ; then
   echo
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;33m█" "▀" "█\e[0m"
   figlet -w 156 "$(basename "$0")" | LC_ALL=C.UTF-8 print-utf8 -x 160 -n -C "\e[1;33m█\e[22m" "\e[1;33m█\e[0m"
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;33m█" "▄" "█\e[0m"
else
   echo -e "\e[1;34;22m########## $(basename "$0") ##########\e[0m"
fi

# Enable printing the command-lines executed:
set -x


# ====== Check/set environment variables ====================================
if [ ! -e /etc/os-release ] ; then
   echo >&2 "ERROR: /etc/os-release does not exist!"
   exit 1
fi
. /etc/os-release


# ###### Main program #######################################################

# ====== Enable source repositories =========================================

# ------ Ubuntu/Debian ------------------------------------------------------
if [ "${ID}" == "ubuntu" ] || [ "${ID}" == "debian" ] ; then

   # Enable APT source repositories:
   (
      if [ -f /etc/apt/sources.list ] ; then
         echo "/etc/apt/sources.list"
      fi
      if [ -d /etc/apt/sources.list.d ] ; then
         find /etc/apt/sources.list.d -mindepth 1 -maxdepth 1 \( -name "*.list" -o -name "*.sources" \)
      fi
   ) | while read -r sourceFile ; do
      if [[ "${sourceFile}" =~ .sources$ ]] ; then
         echo >&2 "Processing sources file: ${sourceFile} ..."
         while IFS= read -r line || [ -n "${line}" ] ; do
            if [[ "${line}" =~ ^(Types:[ \t]) ]] ; then
               types="$(echo "${line}" | cut -d' ' -f2- | xargs -n1 | sort -u | xargs)"
               hasSrc=0
               for type in ${types} ; do
                  if [ "${type}" == "deb-src" ] ; then
                     hasSrc=1
                     break
                  fi
               done
               if [ "${hasSrc}" -eq 0 ] ; then
                  types="${types} deb-src"
               fi
               echo "Types: ${types}"
            else
               echo "${line}"
            fi
         done <"${sourceFile}" >"${sourceFile}.new"
         diff --color "${sourceFile}" "${sourceFile}.new" || true
         mv "${sourceFile}.new" "${sourceFile}"
      elif [[ "${sourceFile}" =~ .list$ ]] ; then
         echo >&2 "Processing list file: ${sourceFile} ..."
         activateSource=0
         while IFS= read -r line || [ -n "${line}" ] ; do
            if [[ "${line}" =~ ^(deb[ \t]) ]] ; then
               echo "${line}"
               activateSource=1
            elif [[ "${line}" =~ ^(# deb-src[ \t]) ]] && [ ${activateSource} -eq 1 ] ; then
               # shellcheck disable=SC2001
               echo "${line}" | sed -e "s/^#[ \t]*//"
               activateSource=0
            else
               echo "${line}"
               activateSource=0
            fi
         done <"${sourceFile}" >"${sourceFile}.new"
         diff --color "${sourceFile}" "${sourceFile}.new" || true
         mv "${sourceFile}.new" "${sourceFile}"
      fi
   done


# ------ Fedora -------------------------------------------------------------
elif [ "${ID}" == "fedora" ] ; then

   true


# ------ FreeBSD ------------------------------------------------------------
elif [ "${ID}" == "freebsd" ] ; then

   # Nothing to do here! FreeBSD sources = ports
   true

# ------ Unknown ------------------------------------------------------------
else

   echo >&2 "ERROR: Unknown ID ${ID} in /etc/os-release. The installation script may need an update for supporting this system!"
   exit 1

fi
