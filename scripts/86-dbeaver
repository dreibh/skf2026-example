# Bash options:
set -euo pipefail


# ====== Print script name, to make Packer output easier readable ===========
if command -v figlet >/dev/null && command -v print-utf8 >/dev/null ; then
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;35m█" "▀" "█\e[0m"
   figlet -w 156 "$(basename "$0")" | LC_ALL=C.UTF-8 print-utf8 -x 160 -n -C "\e[1;35m█\e[22m" "\e[1;35m█\e[0m"
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;35m█" "▄" "█\e[0m"
else
   echo -e "\e[1;34;22m########## $(basename "$0") ##########\e[0m"
fi

# Enable printing the command-lines executed:
set -x


# ====== Check environment variables ========================================
if [ ! -v USER_NAME ] || [ "${USER_NAME}" == "" ] ; then
   echo >&2 "Usage: env USER_NAME=<user> $0"
   echo >&2 "Example: sudo env USER_NAME=nornetpp $0"
   exit 1
fi
USER_HOME="$(getent passwd "${USER_NAME}" | cut -d: -f6 || awk -F: -v user="${USER_NAME}" '$1==user { print $6 }' /etc/passwd)"

if [ ! -e /etc/os-release ] ; then
   echo >&2 "ERROR: /etc/os-release is not available!"
   exit 1
fi
. /etc/os-release


# ====== Install DBeaver Community Edition ==================================

# ------ Debian -------------------------------------------------------------
# Default location:
dbeaverConfigurationDirectory="${USER_HOME}/.local/share/DBeaverData/workspace6"
if [ "${ID}" == "debian" ] ; then

   env DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends flatpak
   flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
   flatpak install -y flathub io.dbeaver.DBeaverCommunity

# ------ Ubuntu -------------------------------------------------------------
elif [ "${ID}" == "ubuntu" ] ; then

   rm -f /etc/apt/preferences.d/block-snapd.pref
   env DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends snapd
   try-hard 3 60 -- snap install --classic dbeaver-ce

   if [ ! -d "${USER_HOME}/snap/dbeaver-ce/current" ] ; then
      dbeaverSnapVersion="$(snap list dbeaver-ce | awk '/^dbeaver-ce/ { print $3 }')"
      sudo -u "${USER_NAME}" mkdir -p "${USER_HOME}/snap/dbeaver-ce/${dbeaverSnapVersion}"
      sudo -u "${USER_NAME}" ln -rs "${USER_HOME}/snap/dbeaver-ce/${dbeaverSnapVersion}" "${USER_HOME}/snap/dbeaver-ce/current"
   else
      dbeaverSnapVersion="current"
   fi
   dbeaverConfigurationDirectory="${USER_HOME}/snap/dbeaver-ce/${dbeaverSnapVersion}/.local/share/DBeaverData/workspace6"

# ------ Fedora -------------------------------------------------------------
elif [ "${ID}" == "fedora" ] ; then

   wget -O /tmp/dbeaver.rpm "https://dbeaver.io/files/dbeaver-ce-latest-stable.x86_64.rpm"
   dnf install --setopt=install_weak_deps=False -y /tmp/dbeaver.rpm

# ------ FreeBSD ------------------------------------------------------------
elif [ "${ID}" == "freebsd" ] ; then

   pkg install -y dbeaver

# ------ Unknown ------------------------------------------------------------
else

   echo >&2 "ERROR: Unknown ID ${ID} in /etc/os-release. The installation script may need an update for supporting this system!"
   exit 1

fi


# ====== Make initial configuration =========================================
sudo -u "${USER_NAME}" mkdir -p "${dbeaverConfigurationDirectory}/General/.dbeaver"
sudo -u "${USER_NAME}" mkdir -p "${dbeaverConfigurationDirectory}/.metadata/.plugins/org.eclipse.core.runtime/.settings"
if [ ! -e "${dbeaverConfigurationDirectory}/General/.dbeaver/data-sources.json" ] ; then

   echo "{}" | sudo -u "${USER_NAME}" tee "${dbeaverConfigurationDirectory}/General/.dbeaver/data-sources.json"

   (
      cat <<EOF
eclipse.preferences.version=1
org.jkiss.dbeaver.core.confirm.exit=never
tipOfTheDayInitializer.notFirstRun=true
ui.show.tip.of.the.day.on.startup=false
EOF
   ) | sudo -u "${USER_NAME}" tee "${dbeaverConfigurationDirectory}/.metadata/.plugins/org.eclipse.core.runtime/.settings/org.jkiss.dbeaver.core.prefs"

   (
      cat <<EOF
eclipse.preferences.version=1
feature.tracking.skipConfirmation=true
EOF
   ) | sudo -u "${USER_NAME}" tee "${dbeaverConfigurationDirectory}/.metadata/.plugins/org.eclipse.core.runtime/.settings/org.jkiss.dbeaver.ui.statistics.prefs"

fi
