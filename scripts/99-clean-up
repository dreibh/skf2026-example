# Bash options:
set -euo pipefail


# ###### Print script name, to make Packer output easier readable ###########
if command -v figlet >/dev/null && command -v print-utf8 >/dev/null ; then
   echo
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;36m█" "▀" "█\e[0m"
   figlet -w 156 "$(basename "$0")" | LC_ALL=C.UTF-8 print-utf8 -x 160 -n -C "\e[1;36m█\e[22m" "\e[1;36m█\e[0m"
   LC_ALL=C.UTF-8 print-utf8 -x 160 -n -s "\e[1;36m█" "▄" "█\e[0m"
else
   echo -e "\e[1;34;22m########## $(basename "$0") ##########\e[0m"
fi

# Enable printing the command-lines executed:
set -x


# ###### Main program #######################################################

# ====== Check/set environment variables ====================================
if [ ! -e /etc/os-release ] ; then
   echo >&2 "ERROR: /etc/os-release does not exist!"
   exit 1
fi
. /etc/os-release
UNAME="$(uname)"


# ====== Reset machine identity =============================================
if [ -e /etc/machine-id ] ; then
   # Ensure to create a new machine ID on the next boot.
   # The machine ID is used e.g. as DHCP Identifier, it must be unique to
   # avoid assigning the same IP address to multiple VMs!
   echo -n | sudo tee /etc/machine-id
   if [ -e /var/lib/dbus/machine-id ] ; then
      sudo truncate -s 0 /var/lib/dbus/machine-id
      if [ -e /var/lib/dbus/machine-id ] ; then
         rm -f /var/lib/dbus/machine-id
      fi
      sudo ln -s /etc/machine-id /var/lib/dbus/machine-id
   fi
fi


# ====== Clean up packages  =================================================

# ------ Ubuntu -------------------------------------------------------------
if [ "${ID}" == "ubuntu" ] || [ "${ID}" == "debian" ] ; then

   apt-get update
   env DEBIAN_FRONTEND=noninteractive NEEDRESTART_MODE=l apt-get dist-upgrade -y
   env DEBIAN_FRONTEND=noninteractive apt-get autoremove -y --purge
   if command -v apt-file 2>/dev/null ; then
      apt-file update
   fi
   if command -v apt-show-versions 2>/dev/null ; then
      apt-show-versions -i
   fi
   apt-get clean

# ------ Fedora -------------------------------------------------------------
elif [ "${ID}" == "fedora" ] ; then

   dnf clean all

# ------ FreeBSD ------------------------------------------------------------
elif [ "${ID}" == "freebsd" ] ; then

   pkg upgrade -y
   pkg clean -y

# ------ Unknown ------------------------------------------------------------
else

   echo >&2 "ERROR: Unknown ID ${ID} in /etc/os-release. The installation script may need an update for supporting this system!"
   exit 1

fi


# ====== Update "locate" database ===========================================
if [ "${UNAME}" == "Linux" ] ; then
   if command -v updatedb 2>/dev/null ; then
      updatedb
   fi
elif [ "${UNAME}" == "FreeBSD" ] ; then
   /etc/periodic/weekly/310.locate
fi


# ====== Run fstrim =========================================================
if [ "${UNAME}" == "Linux" ] ; then
   if command -v fstrim 2>/dev/null ; then
      fstrim -av || true
   fi
elif [ "${UNAME}" == "FreeBSD" ] ; then
   sudo zpool trim zroot
fi


# ====== Run sync ===========================================================
# Just to be sure all data is synced to disk.
# FreeBSD in VirtualBox cannot be shut down cleanly, due a bug!
sync
sync
sync
